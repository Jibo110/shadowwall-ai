# ============================================================
# ShadowWall AI — Environment Variable Contract
# Copy this file to .env and fill in real values.
# .env is NEVER committed to Git.
# Generate secrets with: openssl rand -hex 32
# ============================================================

# --- Application ---
APP_ENV=development
APP_SECRET_KEY=
APP_DEBUG=false

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://shadowwall:shadowwall_pass@localhost:5432/shadowwall_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Cache & Pub/Sub (Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- Authentication (JWT) ---
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- AI (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Security ---
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=60
